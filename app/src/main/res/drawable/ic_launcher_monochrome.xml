<?xml version="1.0" encoding="utf-8"?>
<!--
    忆刻单色图标层（Android 13+ Material You 主题图标使用）
    系统会根据当前壁纸颜色将此图层染色，因此只需提供形状轮廓即可。

    简化的“打开的相册/书本”剪影：
      • 底部厚块 = 书本封底/书脊
      • 左右两片梯形 = 打开的书页，中间在书脊处汇合
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ===== 书本封底/书脊（厚底座）===== -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M26,76 L82,76 L82,86
                          Q82,90 78,90 L30,90
                          Q26,90 26,86 Z" />

    <!-- ===== 左侧书页 ===== -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M30,42 L54,37 L54,80 L27,84 Z" />

    <!-- ===== 右侧书页 ===== -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M78,42 L54,37 L54,80 L81,84 Z" />

</vector>
