<?xml version="1.0" encoding="utf-8"?>
<!--
    忆刻应用图标前景层
    背景层（ic_launcher_background）已经是一张完整的、内容铺满画布的插画
    （相册书本 + "忆刻" 文字），因此前景层保持完全透明，不叠加额外图形，
    避免与背景内容重复或产生视觉冲突。
    使用纯色 shape（alpha=0）而非空 vector，兼容性更好。
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="#00000000" />
</shape>
