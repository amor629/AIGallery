<?xml version="1.0" encoding="utf-8"?>
<!--
    AI Gallery 应用图标前景层
    画布尺寸：108×108dp（自适应图标标准）
    安全区：中心 66dp 圆形（x/y: 21~87），所有关键元素需在此区域内
    本设计使用了三层视觉元素：
      1. 相机机身（白色圆角矩形，含取景器凸起）
      2. 镜头（三层同心圆，制造光圈景深效果）
      3. AI 闪光星（四角星，象征智能 / 魔法处理）
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ===== 相机机身 ===== -->
    <!--
        形状：圆角矩形 (x:30~78, y:36~80) + 顶部取景器凸起 (x:46~62, y:36~42)
        路径顺序（顺时针，从凸起左侧出发）：
          凸起左底 → 凸起左顶 → 凸起右顶 → 凸起右底 →
          右上圆角 → 右下圆角 → 左下圆角 → 左上圆角 → 闭合
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M46,42 L48,36 L60,36 L62,42 L70,42
                          Q78,42 78,50 L78,72
                          Q78,80 70,80 L38,80
                          Q30,80 30,72 L30,50
                          Q30,42 38,42 Z" />

    <!-- ===== 镜头外环（深蓝，制造光圈对比效果）===== -->
    <!-- 圆心 (54,61)，半径 12dp → 左端点 (42,61)，右端点 (66,61) -->
    <path
        android:fillColor="#0D47A1"
        android:pathData="M42,61 A12,12 0 1,0 66,61 A12,12 0 1,0 42,61 Z" />

    <!-- ===== 镜头中环（白色，亮圈效果）===== -->
    <!-- 圆心 (54,61)，半径 8dp → 左端点 (46,61)，右端点 (62,61) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M46,61 A8,8 0 1,0 62,61 A8,8 0 1,0 46,61 Z" />

    <!-- ===== 镜头瞳孔（品牌蓝，景深中心）===== -->
    <!-- 圆心 (54,61)，半径 4dp → 左端点 (50,61)，右端点 (58,61) -->
    <path
        android:fillColor="#1565C0"
        android:pathData="M50,61 A4,4 0 1,0 58,61 A4,4 0 1,0 50,61 Z" />

    <!-- ===== AI 闪光星（四角星，象征智能处理）===== -->
    <!--
        位于相机机身右上角（取景器右侧空白区），中心 (70, 46)
        四个尖角：上(70,41)、右(76,46)、下(70,51)、左(64,46)
        腰部收缩点：右上(71.5,44.5)、右下(71.5,47.5)、左下(68.5,47.5)、左上(68.5,44.5)
    -->
    <path
        android:fillColor="#1565C0"
        android:pathData="M70,41 L71.5,44.5 L76,46 L71.5,47.5 L70,51 L68.5,47.5 L64,46 L68.5,44.5 Z" />

</vector>
