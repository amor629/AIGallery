<?xml version="1.0" encoding="utf-8"?>
<!--
    自适应图标定义（普通版）
    Android 8.0 (API 26) 起支持，minSdk=34 无需提供 PNG 降级版本。
    系统根据设备 OEM 定制决定裁剪形状（圆形 / 圆角方形 / 松鼠形等），
    此处只提供背景层和前景层，裁剪逻辑由系统完成。
    Android 13+ 额外支持 monochrome 层，用于 Material You 主题图标。
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 背景层：品牌蓝色纯色矩形，填充 108×108dp 画布 -->
    <background android:drawable="@drawable/ic_launcher_background" />
    <!-- 前景层：相机 + 镜头 + AI 闪光星，内容集中在中心安全区 -->
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
    <!-- 单色层（Android 13+）：相机轮廓镂空图形，用于壁纸主题着色 -->
    <monochrome android:drawable="@drawable/ic_launcher_monochrome" />
</adaptive-icon>
