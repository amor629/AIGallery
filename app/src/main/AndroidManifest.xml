<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml — 应用清单
    声明权限、组件（Activity）和应用入口
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ======================================================
         媒体读取权限（Android 13+ 细粒度权限）
         ⚠️ 运行时按需申请，不在启动时批量弹窗
         ====================================================== -->
    <!-- 读取图片（Android 13+，API 33+） -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- 读取视频（Android 13+，API 33+） -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <!-- 部分媒体授权：用户可只授权选定的媒体（Android 14+，API 34+） -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />

    <!-- ======================================================
         网络权限
         仅 AI 可选模块使用，用户未配置 Key 时不会发起任何网络请求
         ====================================================== -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".AIGalleryApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AIGallery">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.AIGallery.Starting">
            <!-- 应用启动入口 -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            崩溃友好提示页
            - exported="false"：不对外暴露，只能由 GlobalCrashHandler 内部启动
            - 故意不使用 @AndroidEntryPoint，崩溃时 Hilt 依赖图可能已损坏
        -->
        <activity
            android:name=".crash.CrashActivity"
            android:exported="false"
            android:theme="@style/Theme.AIGallery" />

    </application>

</manifest>
